# Sao chép file này thành .env.local (không commit .env.local lên git) rồi
# điền Project URL + Anon Key lấy từ Supabase Dashboard → Project Settings → API.
#
# Nếu để trống / không tạo file .env.local, ứng dụng vẫn chạy bình thường
# bằng LocalStorage (không có lỗi) — chỉ là dữ liệu không được đồng bộ giữa
# các thiết bị.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

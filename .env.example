# Supabase Dashboard → Project Settings → API
# Dán NGUYÊN VĂN Project URL (bắt đầu bằng https://, ví dụ https://abcdefgh.supabase.co)
VITE_SUPABASE_URL=

# Dán NGUYÊN VĂN anon public key — TOÀN BỘ chuỗi, KHÔNG ghi "..."
# (sb_publishable_xxxxxxxx hoặc eyJ..., thường dài > 100 ký tự)
VITE_SUPABASE_ANON_KEY=
